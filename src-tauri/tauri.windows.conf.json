{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GHA Watch",
        "width": 460,
        "height": 360,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#161b22",
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "targets": ["nsis", "msi"]
  }
}
