{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-set-size",
    "notification:default",
    "opener:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "gh",
          "cmd": "gh",
          "args": true
        },
        {
          "name": "gh-homebrew",
          "cmd": "/opt/homebrew/bin/gh",
          "args": true
        },
        {
          "name": "gh-usrlocal",
          "cmd": "/usr/local/bin/gh",
          "args": true
        },
        {
          "name": "gh-usrbin",
          "cmd": "/usr/bin/gh",
          "args": true
        },
        {
          "name": "gh-windows-program-files",
          "cmd": "C:\\Program Files\\GitHub CLI\\gh.exe",
          "args": true
        },
        {
          "name": "gh-windows-chocolatey",
          "cmd": "C:\\ProgramData\\chocolatey\\bin\\gh.exe",
          "args": true
        }
      ]
    }
  ]
}
