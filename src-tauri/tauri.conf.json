{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GHA Watch",
  "version": "0.1.0",
  "identifier": "dev.jpnurmi.gha-watch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GHA Watch",
        "width": 780,
        "height": 620,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  }
}
